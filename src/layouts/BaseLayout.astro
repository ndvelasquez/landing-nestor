---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Nestor David Velasquez",
  description = "Automation-first product support engineer",
} = Astro.props as Props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        /* Stitch MCP Design System - Digital Curator */
        --surface: #131313;
        --surface-container-lowest: #0e0e0e;
        --surface-container-low: #1c1b1b;
        --surface-container: #201f1f;
        --surface-container-high: #2a2a2a;
        --surface-container-highest: #353534;
        --surface-bright: #3a3939;
        --surface-variant: #353534;
        --primary: #44d8f1;
        --primary-container: #00bcd4;
        --primary-fixed: #a1efff;
        --primary-fixed-dim: #44d8f1;
        --secondary: #70d8c8;
        --secondary-container: #32a192;
        --secondary-fixed: #8df5e4;
        --secondary-fixed-dim: #70d8c8;
        --tertiary: #ffb87b;
        --tertiary-container: #f19640;
        --on-surface: #e5e2e1;
        --on-surface-variant: #bbc9cc;
        --on-primary: #00363e;
        --on-primary-fixed: #001f25;
        --on-primary-container: #004650;
        --on-secondary: #003731;
        --on-secondary-container: #00302a;
        --on-tertiary: #4c2700;
        --outline: #869396;
        --outline-variant: #3c494c;
        --background: #131313;
        --on-background: #e5e2e1;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: 'Manrope', 'Segoe UI', system-ui, -apple-system, sans-serif;
        background-color: var(--surface);
        color: var(--on-surface);
        line-height: 1.6;
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
        scroll-behavior: smooth;
      }
      
      /* Animated glowing orbs */
      body::before,
      body::after {
        content: '';
        position: fixed;
        width: 600px;
        height: 600px;
        border-radius: 50%;
        filter: blur(150px);
        opacity: 0.35;
        z-index: 0;
        animation: float 20s ease-in-out infinite alternate;
        pointer-events: none;
      }
      body::before {
        background: rgba(0, 49, 60, 0.6);
        top: -20%;
        right: -10%;
      }
      body::after {
        background: rgba(154, 219, 232, 0.3);
        bottom: -20%;
        left: -10%;
        animation-delay: -10s;
      }
      @keyframes float {
        0% { transform: translate(0, 0) scale(1); }
        100% { transform: translate(-50px, 50px) scale(1.1); }
      }
      
      main {
        max-width: 960px;
        margin: 0 auto;
        padding: 4rem 1.5rem 6rem;
        position: relative;
        z-index: 1;
      }
      section + section {
        margin-top: 4rem;
      }
      
      h1, h2, h3 {
        color: #ffffff;
        line-height: 1.2;
        margin-bottom: 0.75rem;
        font-weight: 800;
        letter-spacing: -0.02em;
      }
      .text-gradient {
        background: linear-gradient(135deg, #ffffff 0%, #9adbe8 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .text-muted {
        color: var(--text-muted);
      }
      
      /* Glassmorphism Cards */
      .card {
        background: var(--card-bg);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-radius: 24px;
        padding: 3rem;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
        border: 1px solid var(--card-border);
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), 
                    border-color 0.4s ease, 
                    box-shadow 0.4s ease;
      }
      .card:hover {
        transform: translateY(-8px);
        border-color: rgba(154, 219, 232, 0.3);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 
                    0 0 20px rgba(154, 219, 232, 0.1);
      }
      
      /* Hero specific */
      .card.hero {
        background: linear-gradient(135deg, rgba(0, 49, 60, 0.8), rgba(12, 66, 80, 0.8));
        border: 1px solid rgba(154, 219, 232, 0.2);
        position: relative;
        overflow: hidden;
      }
      /* Hero animated shine effect */
      .card.hero::after {
        content: '';
        position: absolute;
        top: 0; left: -100%; width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
        transform: skewX(-20deg);
        animation: shine 8s infinite;
      }
      @keyframes shine {
        0% { left: -100%; }
        20% { left: 200%; }
        100% { left: 200%; }
      }
      .card.hero p {
        color: rgba(255,255,255,0.9);
        font-size: 1.15rem;
      }
      .pill {
        display: inline-flex;
        gap: 0.5rem;
        align-items: center;
        padding: 0.4rem 1rem;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 700;
        background: rgba(154, 219, 232, 0.15);
        color: #9adbe8;
        border: 1px solid rgba(154, 219, 232, 0.3);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1.5rem;
      }
      
      /* CTA Buttons */
      .cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-top: 2rem;
      }
      .cta {
        padding: 0.85rem 1.75rem;
        border-radius: 999px;
        border: none;
        cursor: pointer;
        font-weight: 700;
        font-size: 1rem;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      .cta.primary {
        background: #9adbe8;
        color: #00313c;
        box-shadow: 0 4px 15px rgba(154, 219, 232, 0.3);
      }
      .cta.primary:hover {
        background: #ffffff;
        transform: translateY(-3px) scale(1.02);
        box-shadow: 0 8px 25px rgba(154, 219, 232, 0.5);
      }
      .cta.secondary {
        background: transparent;
        color: #9adbe8;
        border: 1px solid rgba(154, 219, 232, 0.3);
      }
      .cta.secondary:hover {
        background: rgba(154, 219, 232, 0.1);
        border-color: #9adbe8;
        transform: translateY(-3px);
      }
      
      /* Lists & Grids */
      ul.clean {
        list-style: none;
        margin: 1.5rem 0 0;
        padding: 0;
        display: grid;
        gap: 0.75rem;
      }
      ul.clean li {
        padding: 1rem 1.25rem;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        border: 1px solid var(--card-border);
        transition: transform 0.2s ease, background 0.2s ease;
      }
      ul.clean li:hover {
        background: rgba(255, 255, 255, 0.06);
        transform: translateX(5px);
      }
      
      ul.timeline {
        border-left: 2px solid rgba(154, 219, 232, 0.2);
        padding-left: 2rem;
        margin: 1.5rem 0 0;
        display: grid;
        gap: 2rem;
      }
      ul.timeline li {
        position: relative;
      }
      ul.timeline li::before {
        content: '';
        position: absolute;
        left: -2.35rem;
        top: 0.4rem;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: var(--surface);
        border: 2px solid var(--glow);
        transition: background 0.3s ease, transform 0.3s ease;
      }
      ul.timeline li:hover::before {
        background: var(--glow);
        transform: scale(1.2);
        box-shadow: 0 0 10px var(--glow);
      }
      
      .automation-grid {
        display: grid;
        gap: 1.5rem;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        margin-top: 1.5rem;
      }
      .automation-card {
        background: rgba(255, 255, 255, 0.03);
        border-radius: 20px;
        padding: 2rem;
        border: 1px solid var(--card-border);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        display: flex;
        flex-direction: column;
        align-items: flex-start;
      }
      .automation-card .icon-wrapper {
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.25rem;
        background: rgba(154, 219, 232, 0.08);
        border-radius: 16px;
        padding: 0.75rem;
      }
      .automation-card img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        filter: drop-shadow(0 8px 16px rgba(154, 219, 232, 0.2));
        transition: transform 0.4s ease, filter 0.4s ease;
      }
      .automation-card:hover {
        transform: translateY(-8px);
        background: rgba(255, 255, 255, 0.06);
        border-color: rgba(154, 219, 232, 0.4);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
      }
      .automation-card:hover img {
        transform: scale(1.08);
        filter: drop-shadow(0 12px 24px rgba(154, 219, 232, 0.35));
      }
      
      /* Scroll Animations & Staggering */
      .reveal {
        opacity: 0;
        transform: translateY(40px);
        transition: all 0.8s cubic-bezier(0.5, 0, 0, 1);
      }
      .reveal.active {
        opacity: 1;
        transform: translateY(0);
      }
      .delay-1 { transition-delay: 0.1s; }
      .delay-2 { transition-delay: 0.2s; }
      .delay-3 { transition-delay: 0.3s; }
      .delay-4 { transition-delay: 0.4s; }

      @media (max-width: 720px) {
        main { padding: 2.5rem 1.25rem 4rem; }
        .card { padding: 2rem 1.5rem; }
        h1 { font-size: 2rem; }
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
    
    <script>
      // Setup Intersection Observer for scroll animations
      const setupObserver = () => {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('active');
              // Unobserve to run animation only once per load
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

        document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
      };

      // Run on initial load
      setupObserver();
    </script>
  </body>
</html>
