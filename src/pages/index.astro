---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Nestor Velasquez | Digital Curator & Developer">
  <!-- Top Navigation Bar -->
  <nav class="fixed top-0 w-full z-50 bg-surface/50 dark:bg-[#131313]/50 backdrop-blur-xl shadow-[0_0_40px_-5px_rgba(68,216,241,0.08)]">
    <div class="flex justify-between items-center px-8 py-4 max-w-7xl mx-auto">
      <div class="text-xl font-bold tracking-tighter text-[#e5e2e1] font-headline">
        Nestor Velasquez
      </div>
      <div class="hidden md:flex items-center space-x-8">
        <a class="font-manrope tracking-tight text-sm font-medium text-[#44d8f1] border-b-2 border-[#44d8f1] pb-1" href="#hero">Hero</a>
        <a class="font-manrope tracking-tight text-sm font-medium text-[#e5e2e1]/70 hover:text-[#44d8f1] transition-colors duration-300" href="#about">About</a>
        <a class="font-manrope tracking-tight text-sm font-medium text-[#e5e2e1]/70 hover:text-[#44d8f1] transition-colors duration-300" href="#skills">Skills</a>
        <a class="font-manrope tracking-tight text-sm font-medium text-[#e5e2e1]/70 hover:text-[#44d8f1] transition-colors duration-300" href="#projects">Projects</a>
        <a class="font-manrope tracking-tight text-sm font-medium text-[#e5e2e1]/70 hover:text-[#44d8f1] transition-colors duration-300" href="#contact">Contact</a>
      </div>
      <a href="#contact">
        <button class="bg-gradient-to-r from-primary to-primary-container text-on-primary-fixed px-5 py-2 rounded-DEFAULT font-medium text-sm hover:shadow-[0_0_15px_rgba(68,216,241,0.3)] transition-all duration-300 scale-95 active:scale-90">
          Get in Touch
        </button>
      </a>
    </div>
  </nav>

  <main>
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20 mesh-gradient" id="hero">
      <div class="max-w-7xl mx-auto px-8 w-full relative z-10">
        <div class="max-w-3xl">
          <h1 class="text-6xl md:text-8xl font-black tracking-tighter leading-[0.9] text-primary-fixed mb-6">
            Digital Curator <br/>
            <span class="bg-gradient-to-r from-primary via-secondary to-primary bg-clip-text text-transparent opacity-90">& Developer</span>
          </h1>
          <p class="text-xl md:text-2xl text-on-surface-variant font-light mb-10 max-w-xl">
            Crafting modern digital experiences with precision and intentional asymmetry.
          </p>
          <div class="flex flex-wrap gap-4">
            <a class="bg-gradient-to-r from-primary to-primary-container text-on-primary-fixed px-8 py-4 rounded-DEFAULT font-bold tracking-tight hover:shadow-[0_0_25px_rgba(68,216,241,0.4)] transition-all duration-300 transform hover:-translate-y-1" href="#projects">
              View My Work
            </a>
            <a class="px-8 py-4 rounded-DEFAULT border border-outline-variant/30 backdrop-blur-sm text-on-surface hover:bg-surface-container-highest/20 transition-all duration-300" href="#about">
              Learn More
            </a>
          </div>
        </div>
      </div>
      <!-- Asymmetric Decoration -->
      <div class="absolute right-0 top-1/2 -translate-y-1/2 w-1/3 h-2/3 opacity-20 pointer-events-none">
        <div class="w-full h-full bg-primary/20 blur-[120px] rounded-full translate-x-1/2"></div>
      </div>
    </section>

    <!-- About Section -->
    <section class="py-32 bg-surface-container-low" id="about">
      <div class="max-w-7xl mx-auto px-8">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-16 items-center">
          <div class="md:col-span-5 relative">
            <div class="aspect-[4/5] bg-surface-container-high rounded-lg overflow-hidden glass-card">
              <img 
                alt="Nestor Velasquez portrait" 
                class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700" 
                src="https://lh3.googleusercontent.com/aida/AB6AXuAmYFqDa0YJmEuITpCimon8VkZiql6vgEba0OruLaV4RhWfXIbhuvwS9LPmSQe6IEp-38j6kS0TEBQCnEyBPHTvYmLF5CU5r7JjNKOgRUhcHPvoD98yKxBi8JQ02f22VuEq6XYpRVopI8sJ42jqfA9fmzKP_fqU4jdxnLc3rt-ZTuOteYW-65Jecj69-wE6UmT5GOScBYdVXixQ5xvbXVB7uqJhJ7Gxp92RIt8ov1mbnDYLlBzzegvgg07YYpK5sPeKXSVyXF7SPA"
              />
            </div>
            <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-primary/10 backdrop-blur-xl border border-primary/20 flex items-center justify-center p-4">
              <span class="text-primary font-black text-4xl">08+</span>
            </div>
          </div>
          <div class="md:col-span-7">
            <h2 class="text-sm font-bold tracking-[0.2em] uppercase text-secondary mb-4">About the Curator</h2>
            <h3 class="text-4xl md:text-5xl font-extrabold tracking-tight text-on-surface mb-8">Engineering Artistry in Code.</h3>
            <div class="space-y-6 text-lg text-on-surface-variant font-light leading-relaxed">
              <p>
                I specialize in building digital architectures that don't just function—they resonate. By bridging the gap between high-end UI/UX design and scalable engineering, I create environments where performance meets aesthetic excellence.
              </p>
              <p>
                My approach is rooted in the "No-Line" philosophy, using depth, light, and motion to define boundaries rather than rigid grids. Every pixel is an intentional choice in a larger narrative of digital sophistication.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills Section -->
    <section class="py-32 bg-surface" id="skills">
      <div class="max-w-7xl mx-auto px-8">
        <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
          <div class="max-w-2xl">
            <h2 class="text-sm font-bold tracking-[0.2em] uppercase text-tertiary mb-4">Technical Arsenal</h2>
            <h3 class="text-4xl md:text-5xl font-extrabold tracking-tight text-on-surface">The Tools of Precision.</h3>
          </div>
          <div class="text-on-surface-variant text-right max-w-xs font-light italic">
            "Precision is the difference between a tool and an instrument."
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-24 gap-y-12">
          <!-- Skill Item -->
          <div class="space-y-4">
            <div class="flex justify-between items-center text-sm font-bold tracking-tight uppercase">
              <span class="text-on-surface">JavaScript / TypeScript</span>
              <span class="text-primary">95%</span>
            </div>
            <div class="h-[2px] w-full bg-surface-container-highest relative">
              <div class="absolute top-0 left-0 h-full bg-gradient-to-r from-primary to-primary-container shadow-[0_0_15px_rgba(68,216,241,0.5)] w-[95%]"></div>
            </div>
          </div>
          <!-- Skill Item -->
          <div class="space-y-4">
            <div class="flex justify-between items-center text-sm font-bold tracking-tight uppercase">
              <span class="text-on-surface">React / Next.js</span>
              <span class="text-primary">92%</span>
            </div>
            <div class="h-[2px] w-full bg-surface-container-highest relative">
              <div class="absolute top-0 left-0 h-full bg-gradient-to-r from-primary to-primary-container shadow-[0_0_15px_rgba(68,216,241,0.5)] w-[92%]"></div>
            </div>
          </div>
          <!-- Skill Item -->
          <div class="space-y-4">
            <div class="flex justify-between items-center text-sm font-bold tracking-tight uppercase">
              <span class="text-on-surface">Tailwind CSS</span>
              <span class="text-primary">98%</span>
            </div>
            <div class="h-[2px] w-full bg-surface-container-highest relative">
              <div class="absolute top-0 left-0 h-full bg-gradient-to-r from-primary to-primary-container shadow-[0_0_15px_rgba(68,216,241,0.5)] w-[98%]"></div>
            </div>
          </div>
          <!-- Skill Item -->
          <div class="space-y-4">
            <div class="flex justify-between items-center text-sm font-bold tracking-tight uppercase">
              <span class="text-on-surface">UI/UX Design</span>
              <span class="text-primary">88%</span>
            </div>
            <div class="h-[2px] w-full bg-surface-container-highest relative">
              <div class="absolute top-0 left-0 h-full bg-gradient-to-r from-primary to-primary-container shadow-[0_0_15px_rgba(68,216,241,0.5)] w-[88%]"></div>
            </div>
          </div>
          <!-- Skill Item -->
          <div class="space-y-4">
            <div class="flex justify-between items-center text-sm font-bold tracking-tight uppercase">
              <span class="text-on-surface">Node.js / Express</span>
              <span class="text-primary">90%</span>
            </div>
            <div class="h-[2px] w-full bg-surface-container-highest relative">
              <div class="absolute top-0 left-0 h-full bg-gradient-to-r from-primary to-primary-container shadow-[0_0_15px_rgba(68,216,241,0.5)] w-[90%]"></div>
            </div>
          </div>
          <!-- Skill Item -->
          <div class="space-y-4">
            <div class="flex justify-between items-center text-sm font-bold tracking-tight uppercase">
              <span class="text-on-surface">Automation (n8n, Make)</span>
              <span class="text-primary">85%</span>
            </div>
            <div class="h-[2px] w-full bg-surface-container-highest relative">
              <div class="absolute top-0 left-0 h-full bg-gradient-to-r from-primary to-primary-container shadow-[0_0_15px_rgba(68,216,241,0.5)] w-[85%]"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Projects Section (Bento Grid Style) -->
    <section class="py-32 bg-surface-container-lowest" id="projects">
      <div class="max-w-7xl mx-auto px-8">
        <div class="text-center mb-20">
          <h2 class="text-sm font-bold tracking-[0.2em] uppercase text-primary mb-4">Curated Exhibition</h2>
          <h3 class="text-4xl md:text-6xl font-extrabold tracking-tighter text-on-surface">Selected Projects</h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
          <!-- Project 1 (Large) -->
          <div class="md:col-span-8 group relative aspect-video md:aspect-auto md:h-[600px] overflow-hidden rounded-lg bg-surface-container-high">
            <img 
              alt="AI Automation Platform" 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-60" 
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuCCJ5uuOBLRJMUSE3tDf0Shl0kzNNMgjpZ6PRlPCgrexF1qSrY4N9h0vMGkF5QECxwvja1pHB50x7Hz_Nnsm0y7paccZgDrgFqSzhMSvbUs0Qb-GEfreAkW58ZtGIr1sGs-F-hTUnP-7SnpJAiVWUjCej--XfcPtEDtWKobIwAvIyAGWTajXgLilQRDttUnaO70Y7JxgzSOI--9JbZOS463SHzPVStaLLcXwwmvuQmba-QOCQ2I1Q_BxcJWR0UcY6ZJP4Jqcgr06A"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-surface via-transparent to-transparent opacity-90"></div>
            <div class="absolute bottom-0 left-0 p-10">
              <div class="flex gap-2 mb-4">
                <span class="px-3 py-1 rounded-full bg-secondary-container/20 text-secondary text-xs font-bold border border-secondary/20 uppercase tracking-widest">AI / ML</span>
                <span class="px-3 py-1 rounded-full bg-primary-container/20 text-primary text-xs font-bold border border-primary/20 uppercase tracking-widest">Automation</span>
              </div>
              <h4 class="text-3xl font-bold text-on-surface mb-2">AI Automation Platform</h4>
              <p class="text-on-surface-variant font-light max-w-md">Intelligent workflow automation with real-time analytics and neural pattern recognition.</p>
            </div>
            <div class="absolute top-10 right-10 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <span class="material-symbols-outlined text-primary text-4xl">arrow_outward</span>
            </div>
          </div>
          <!-- Project 2 (Small) -->
          <div class="md:col-span-4 group relative overflow-hidden rounded-lg bg-surface-container-high h-[600px]">
            <img 
              alt="Landing Page Generator" 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-60" 
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuAxOVBOS4P6402IpWgQNdV7unEuIAMmXfHHnlrTa_fLFgya7Z1fSv2YpoDHg-ndlAXwPMW1mbHXcQCtuGz2hQCAfMFuriTfEB4gMdbR0dxcRdsleXR9q8Lp8Gk93Br44OUY0v9bUTQPfHtOo8ole6Pr743zaBp0B5IGEV46F2_sJGaXaX6ZQuxU7WkC2J-ZNdRT39-IoYEh08A8mwKuQ6yRZ-qI8001Bk4PkK8NI-0SjycQOmOt_s8NpaurL8uCfqg8tyeyKnlSuA"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-surface via-transparent to-transparent opacity-90"></div>
            <div class="absolute bottom-0 left-0 p-8">
              <div class="flex gap-2 mb-4">
                <span class="px-3 py-1 rounded-full bg-tertiary-container/20 text-tertiary text-xs font-bold border border-tertiary/20 uppercase tracking-widest">Web Dev</span>
              </div>
              <h4 class="text-2xl font-bold text-on-surface mb-2">Landing Page Generator</h4>
              <p class="text-on-surface-variant font-light text-sm">AI-powered landing page creation with Stitch MCP and modern design systems.</p>
            </div>
          </div>
          <!-- Project 3 (Medium) -->
          <div class="md:col-span-12 group relative h-[400px] overflow-hidden rounded-lg bg-surface-container-high">
            <img 
              alt="Content Automation System" 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-40" 
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuBRM3c2KlgiXHFv0tEmBurrLRsxP9YXeodfDfnrh9hORIYoZ4kmN5UmxnS65Fi4_slZG7FkORsxOoMNdYxRRYxV8WTjFypYNEY80UtsrySqABy2hiGcJzBU8_NfECqiMZe0mDd2IeByb8TLndQKZ4-7_hDlXLiZSfgOCV59EcwsPVRm0FC4mORnJwmrDcC_uhu_adfHDYMgRM6qx1ZFR6pBJCF1uedyYHAiT4EEAlpJImMoBK9Y_WY1lbO6lpgu8k489jd_YwpYDQ"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-surface via-surface/40 to-transparent"></div>
            <div class="absolute inset-y-0 left-0 p-12 flex flex-col justify-center">
              <div class="flex gap-2 mb-4">
                <span class="px-3 py-1 rounded-full bg-primary-container/20 text-primary text-xs font-bold border border-primary/20 uppercase tracking-widest">Content</span>
                <span class="px-3 py-1 rounded-full bg-secondary-container/20 text-secondary text-xs font-bold border border-secondary/20 uppercase tracking-widest">Automation</span>
              </div>
              <h4 class="text-4xl font-bold text-on-surface mb-2">Content Automation System</h4>
              <p class="text-on-surface-variant font-light max-w-xl">Multi-platform content generation and scheduling with LinkedIn, Notion, and n8n integration.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="py-32 bg-surface mesh-gradient" id="contact">
      <div class="max-w-7xl mx-auto px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-20">
          <div>
            <h2 class="text-sm font-bold tracking-[0.2em] uppercase text-primary mb-4">Inquiry</h2>
            <h3 class="text-5xl font-extrabold tracking-tighter text-on-surface mb-8">Let's build <br/>something legendary.</h3>
            <p class="text-on-surface-variant text-xl font-light mb-12">
              Currently accepting select freelance projects and collaborative inquiries for 2026.
            </p>
            <div class="space-y-6">
              <div class="flex items-center gap-4 text-on-surface">
                <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center border border-outline-variant/20">
                  <span class="material-symbols-outlined text-primary">mail</span>
                </div>
                <span class="text-lg font-medium">ndvelasquezl@gmail.com</span>
              </div>
              <div class="flex items-center gap-4 text-on-surface">
                <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center border border-outline-variant/20">
                  <span class="material-symbols-outlined text-primary">location_on</span>
                </div>
                <span class="text-lg font-medium">Remote / Global</span>
              </div>
            </div>
          </div>
          <div class="bg-surface-container-low p-8 md:p-12 rounded-lg border border-outline-variant/10 shadow-2xl">
            <form action="#" class="space-y-6">
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Your Name</label>
                <input class="w-full bg-surface-container-lowest border-none focus:ring-1 focus:ring-primary/40 text-on-surface py-4 px-4 rounded-DEFAULT transition-all" placeholder="Enter your name" type="text"/>
              </div>
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Email Address</label>
                <input class="w-full bg-surface-container-lowest border-none focus:ring-1 focus:ring-primary/40 text-on-surface py-4 px-4 rounded-DEFAULT transition-all" placeholder="name@company.com" type="email"/>
              </div>
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Project Details</label>
                <textarea class="w-full bg-surface-container-lowest border-none focus:ring-1 focus:ring-primary/40 text-on-surface py-4 px-4 rounded-DEFAULT transition-all" placeholder="Tell me about your vision..." rows="4"></textarea>
              </div>
              <button class="w-full bg-primary text-on-primary-fixed font-bold py-5 rounded-DEFAULT shadow-[0_10px_30px_-10px_rgba(68,216,241,0.3)] hover:shadow-[0_15px_40px_-10px_rgba(68,216,241,0.5)] transition-all transform hover:-translate-y-1" type="submit">
                Send Message
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="bg-[#0e0e0e] dark:bg-[#0e0e0e] w-full border-t border-[#3c494c]/20">
    <div class="flex flex-col md:flex-row justify-between items-center px-12 py-10 w-full max-w-7xl mx-auto">
      <div class="mb-6 md:mb-0">
        <div class="text-lg font-black text-[#44d8f1] mb-2 font-headline">Nestor Velasquez</div>
        <p class="font-manrope text-xs tracking-wide uppercase text-[#e5e2e1]/50">
          © 2026 Digital Curator. Engineered with Precision.
        </p>
      </div>
      <div class="flex flex-wrap justify-center gap-8">
        <a class="font-manrope text-xs tracking-wide uppercase text-[#e5e2e1]/50 hover:text-[#70d8c8] hover:translate-y-[-2px] transition-all duration-200" href="https://www.linkedin.com/in/nestor-david-velasquez/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a class="font-manrope text-xs tracking-wide uppercase text-[#e5e2e1]/50 hover:text-[#70d8c8] hover:translate-y-[-2px] transition-all duration-200" href="https://github.com/ndvelasquez" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a class="font-manrope text-xs tracking-wide uppercase text-[#e5e2e1]/50 hover:text-[#70d8c8] hover:translate-y-[-2px] transition-all duration-200" href="#" target="_blank" rel="noopener noreferrer">Portfolio</a>
      </div>
    </div>
  </footer>

  <style>
    body {
      background-color: #131313;
      color: #e5e2e1;
      font-family: 'Manrope', sans-serif;
      scroll-behavior: smooth;
    }
    .mesh-gradient {
      background: radial-gradient(at 0% 0%, rgba(0, 188, 212, 0.15) 0px, transparent 50%),
                  radial-gradient(at 100% 100%, rgba(112, 216, 200, 0.1) 0px, transparent 50%);
    }
    .glass-card {
      background: rgba(53, 53, 52, 0.05);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(60, 73, 76, 0.1);
    }
  </style>
</BaseLayout>
